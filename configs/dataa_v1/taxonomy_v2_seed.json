  "qwen_normalization_rules": {
    "prefer_real_person_when_visible_and_not_tiny": true,
    "mark_uncertain_if_no_taxonomy_label_fits": true,
    "do_not_map_aircraft_to_road_vehicle": true,
    "do_not_map_rail_vehicle_to_road_vehicle": true,
    "do_not_map_street_light_to_indoor_lamp": true,
    "surface_text_regions_are_carrier_surfaces_not_internal_text": true,
    "non_sam3_labels_must_use_blocked_operation": true,
    "map_unbounded_scene_structures_to_blocked": [
      "building", "wall", "window", "door", "floor", "ceiling", "road",
      "street", "bridge", "fence", "railing", "staircase"
    ],
    "map_natural_background_to_blocked": [
      "sky", "cloud", "ocean", "water", "river", "lake", "grass", "ground",
      "mountain", "forest", "sand", "snow"
    ],
    "map_text_overlay_logo_to_blocked": [
      "subtitle", "watermark", "logo", "hud", "text overlay", "on-screen text"
    ],
    "map_dynamic_material_to_blocked": [
      "smoke", "fog", "mist", "fire", "flame", "particles", "splash", "waves"
    ]
  },
